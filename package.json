{
  "name": "checkers-eval-api",
  "version": "0.1.0",
  "description": "Checkers with random play and game history saved to disk and connected training NN",
  "scripts": {
    "start:data-server": "(cd data-server && node server.js)",
    "dev:data-server": "(cd data-server && node server.js)",
    "start:checkers-ui": "(cd checkers-ui && npx serve)",
    "dev:ui": "cd checkers-ui-vue && npm run dev",
    "build:ui": "cd checkers-ui-vue && npm run build",
    "start:engine-api": "(cd engine-api && node dist/index.js)",
    "build:engine-api": "(cd engine-api && tsc)",
    "dev:engine-api": "(cd engine-api && ts-node-dev --respawn src/index.ts)"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "onnxruntime-node": "^1.24.1",
    "pinia": "^3.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
